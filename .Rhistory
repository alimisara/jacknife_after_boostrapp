library(ISLR)
data(Default)
dat <- data.frame(Default)
dat$default <- factor(dat$default)
dat$student <- factor(dat$student)
mod_logit <- glm(
default ~ student + balance + income,
data = dat,
family = binomial(link = "logit")
)
summary(mod_logit)
# Matrice de design
X <- model.matrix(default ~ student + balance + income, data = dat)
# Variable réponse en 0/1
y <- as.numeric(dat$default) - 1
beta0 <- rep(0, ncol(X))
res_NR_logit <- newton_raphson_logit(y, X, beta0)
newton_raphson_logit <- function(y, X, beta_init, tol = 1e-6, max_iter = 100) {
beta <- beta_init
n <- length(y)
for (iter in 1:max_iter) {
eta <- X %*% beta
pi <- 1 / (1 + exp(-eta))   # fonction logistique
# Score
score <- t(X) %*% (y - pi)
# Hessienne
W <- diag(as.vector(pi * (1 - pi)))
hessian <- - t(X) %*% W %*% X
# Mise à jour
beta_new <- beta - solve(hessian) %*% score
# Critère d'arrêt
if (max(abs(beta_new - beta)) < tol) {
return(list(
coefficients = beta_new,
iterations = iter,
converged = TRUE
))
}
beta <- beta_new
}
return(list(
coefficients = beta,
iterations = max_iter,
converged = FALSE
))
}
# Matrice de design
X <- model.matrix(default ~ student + balance + income, data = dat)
# Variable réponse en 0/1
y <- as.numeric(dat$default) - 1
beta0 <- rep(0, ncol(X))
res_NR_logit <- newton_raphson_logit(y, X, beta0)
res_NR_logit$coefficients
res_NR_logit$iterations
res_NR_logit$converged
coef(mod_logit)
