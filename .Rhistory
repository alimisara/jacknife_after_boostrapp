w <- (phi^2) / (Phi * (1 - Phi))
-t(X) %*% (X * as.vector(w))
}
newton_raphson_probit <- function(y, X, beta0,
tol = 1e-6,
maxit = 100) {
beta <- beta0
for (i in 1:maxit) {
S <- score_probit(beta, y, X)
H <- hessian_probit(beta, y, X)
beta_new <- beta - solve(H, S)
if (max(abs(beta_new - beta)) < tol) {
return(list(
coefficients = beta_new,
iterations = i,
logLik = loglik_probit(beta_new, y, X)
))
}
beta <- beta_new
}
stop("Non convergence")
}
