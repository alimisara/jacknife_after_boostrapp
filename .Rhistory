biais_boot_moy <- mean(biais_boot_i, na.rm = TRUE) # La moyenne des biais boots
# Ecart_type de jackknife
ecart_type_jack <- sqrt(((n - 1) / n) * sum((biais_boot_i - biais_boot_moy)^2, na.rm = TRUE))
ecart_type_jack
